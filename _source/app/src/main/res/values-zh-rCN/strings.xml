    <!-- Onboarding -->
    <string name="onb_welcome_title">欢迎使用 Suitefish</string>
    <string name="onb_welcome_body">Suitefish 是一款轻量级的开源应用商店客户端。它连接到在线目录服务器，列出可用的应用，并允许你下载和安装它们。</string>

    <string name="risk_title">使用风险自负</string>
    <string name="risk_body">你使用 Suitefish 完全由自己承担风险。此应用会从官方应用商店之外的在线来源安装软件。\n\n使用错误的、恶意的或配置不当的自定义服务器可能使你面临漏洞、恶意软件或数据泄露的风险。请仅连接你完全信任的服务器。对于因使用此应用或自定义服务器而导致的任何损害、数据丢失或安全事件，开发者和 Suitefish 均不承担责任。</string>

    <string name="privacy_title">隐私声明</string>
    <string name="privacy_body_default">Suitefish 当前配置为使用默认服务器。\n\n使用默认服务器时，应用会从 suitefish.com 网站获取其数据（应用列表、图片和下载）。继续即表示你接受 suitefish.com 上发布的数据政策。请在使用应用前查看该政策。\n\n此声明会在每次启动时显示。</string>
    <string name="privacy_body_custom">Suitefish 当前配置为使用自定义服务器：\n\n%1$s\n\n所有应用列表、图片和下载都将从该服务器获取。Suitefish 无法验证自定义服务器的可信度或隐私做法——你需对所连接的服务器负责。\n\n此声明会在每次启动时显示。</string>
    <string name="privacy_accept">我理解并接受</string>
    <string name="privacy_decline">退出</string>

    <!-- Server selection -->
    <string name="server_choose_title">选择服务器</string>
    <string name="server_choose_body">Suitefish 需要一个目录服务器来加载应用。你可以使用默认服务器，或将应用指向你自己的自定义服务器。此选择会被保存，稍后可在设置中更改。</string>
    <string name="server_default">默认服务器</string>
    <string name="server_default_sub">使用官方 suitefish.com 目录。</string>
    <string name="server_custom">自定义服务器</string>
    <string name="server_custom_sub">连接到你自己的目录服务器。</string>
    <string name="server_custom_help">必须使用 HTTPS 并强制执行。请输入可访问的在线域名或 IP。若要使用 443 以外的端口，请附加 :端口（例如 example.com:8443）。</string>
    <string name="onb_accept_risk">我理解并接受这些风险</string>

    <!-- Insecure TLS toggle -->
    <string name="allow_insecure_title">允许不受信任的证书</string>
    <string name="allow_insecure_onb">允许不受信任 / 自签名证书</string>
    <string name="allow_insecure_sub">接受自签名或其他不受信任的 HTTPS 证书。仅对你控制并信任的服务器启用此选项。</string>
    <string name="allow_insecure_warn_title">禁用证书检查？</string>
    <string name="allow_insecure_warn_body">启用此选项会使 Suitefish 停止验证服务器的 HTTPS 证书。届时流量可能被中间人（man-in-the-middle）拦截或篡改，使你面临恶意软件或数据泄露的风险。仅对你完全信任的自托管服务器启用此选项。\n\n仍要启用吗？</string>
    <string name="allow_insecure_enable">启用</string>
    <string name="server_continue">继续</string>
    <string name="server_invalid">服务器无效。请输入有效的在线域名或 IP。强制使用 HTTPS；只能添加 :端口。</string>
    <string name="server_unreachable">无法通过 HTTPS 访问服务器。请检查地址和你的连接。</string>

